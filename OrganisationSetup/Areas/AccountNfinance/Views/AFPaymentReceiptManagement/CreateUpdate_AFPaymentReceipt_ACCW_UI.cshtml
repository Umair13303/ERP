@using SharedUI.Models.Enums
@{
    Layout = "LayoutOne";
}

<div class="container-fluid py-2">
    @* --- HEADER SECTION --- *@
    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 pb-3">
        <div>
            <h4 class="fw-bold mb-0">@ViewBag.DisplayName</h4>
            <p class="text-muted small mb-0">Fill in the details to create a new system record.</p>
        </div>
        <div>
            @if (ViewBag.OperationType == nameof(OperationType.INSERT_DATA_INTO_DB))
            {
                <button type="button" id="ButtonSaveData" class="btn btn-primary btn-sm px-4 shadow-sm">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save
                </button>
            }
            else if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
            {
                <button type="button" id="ButtonUpdateData" class="btn btn-success btn-sm px-4 shadow-sm">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Update
                </button>
            }
        </div>
    </div>

    <form id="AFPaymentReceipt">
        @Html.Hidden("OperationType", (string)ViewBag.OperationType)
        @Html.Hidden("GuID")
        @Html.Hidden("PaymentTypeId", (int)PaymentType.onAccount)

        @if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body py-2">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.Label("DropDownListDocument", "Document (Payment)", new { @class = "col-form-label col-form-label-sm fw-bold" })
                                @Html.DropDownList("DocumentGuID", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", @id = "DropDownListDocument" })
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="bg-light rounded-2 border-start border-primary border-4 p-2 mb-4">
                    <span class="fw-bold text-primary small"><i class="fa-solid fa-building me-2"></i> PAYMENT INFORMATION</span>
                </div>

                <div class="row">
                    <div class="col-lg-5 border-end">
                        <div class="row g-3">
                            <div class="col-md-6">
                                @Html.Label("DropDownListLocation", "Location", new { @class = "form-label small mb-1" })
                                @Html.DropDownList("LocationId", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", @id = "DropDownListLocation", required = "required" })
                            </div>
                            <div class="col-md-6">
                                @Html.Label("DropDownListTransactionDate", "Transaction Date", new { @class = "form-label small mb-1" })
                                @Html.TextBox("TransactionDate", null, new { @class = "form-control form-control-sm", required = "required", @id = "TextBoxTransactionDate", @type = "date" })
                            </div>

                            <div class="col-12">
                                @Html.Label("DropDownListCustomer", "Customer", new { @class = "form-label small mb-1" })
                                @Html.DropDownList("CustomerId", Enumerable.Empty<SelectListItem>(), "Select An Option", new { @class = "form-select form-select-sm select2", required = "required", @id = "DropDownListCustomer" })
                            </div>

                            <div class="col-12">
                                @Html.Label("TextBoxDescription", "Description", new { @class = "form-label small mb-1" })
                                @Html.TextBox("Description", null, new { @class = "form-control form-control-sm", required = "required", @id = "TextBoxDescription", })
                            </div>

                            <div class="col-md-6">
                                @Html.Label("DropDownListPaymentMethod", "Payment Method", new { @class = "form-label small mb-1" })
                                @Html.DropDownList("PaymentMethodId", Enumerable.Empty<SelectListItem>(), "Select An Option", new { @class = "form-select form-select-sm select2", @id = "DropDownListPaymentMethod" })
                            </div>
                            <div class="col-md-6">
                                @Html.Label("TextBoxReference", "Reference", new { @class = "form-label small mb-1" })
                                @Html.TextBox("Reference", null, new { @class = "form-control form-control-sm", placeholder = "Payment Reference", @id = "TextBoxReference" })
                            </div>

                            <div class="col-md-6">
                                @Html.Label("TextBoxReceiptAmount", "Amount", new { @class = "form-label small mb-1" })
                                @Html.TextBox("ReceiptAmount", null, new { @class = "form-control form-control-sm", placeholder = "0.00", @type = "number", @step = "0.01", required = "required", @id = "TextBoxReceiptAmount" })
                            </div>

                            @if (ViewBag.OperationType == nameof(OperationType.INSERT_DATA_INTO_DB))
                            {
                                <button type="button" id="ButtonSaveData" class="btn btn-primary btn-sm px-4 shadow-sm">
                                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save
                                </button>
                            }
                            else if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
                            {
                                <button type="button" id="ButtonUpdateData" class="btn btn-success btn-sm px-4 shadow-sm">
                                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Update
                                </button>
                            }
                        </div>
                    </div>

                    <div class="col-lg-7 ps-lg-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold text-primary small">PAYMENT HISTORY</span>
                        </div>
                        <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
                           <table class="table table-sm table-hover" style="font-size: 0.72rem;" id="TableCustomerLedger">
                                <tbody id="TableBodyCustomerLedger">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div> 
            </div>
        </div> 
    </form>
</div>
<script>
    var LocationId = @ViewBag.LocationId;
</script>
<script src="~/js/accountnfinance/createupdate_afpaymentreceipt_accw_uiscript.js"></script>