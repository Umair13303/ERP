@model OrganisationSetup.Areas.AccountNfinance.Controllers.AFReportController.InvoicePrintVm
@{
    Layout = null;
    var isThermal = Model.ReportType == OrganisationSetup.Areas.AccountNfinance.Controllers.AFReportController.InvoiceRptType.ThermalPrint;
    var qrCodeUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={Uri.EscapeDataString(Model.Header.Code ?? Model.Header.GuID.ToString())}";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice - @Model.Header.Code</title>
    <style>
        @@page {
            size: @(isThermal ? "80mm auto" : "A4");
            margin: @(isThermal ? "1mm" : "15mm");
        }

        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: @(isThermal ? "12px" : "13px");
            color: #000;
            line-height: 1.2;
            margin: 0;
            padding: @(isThermal ? "2px" : "0");
            width: @(isThermal ? "76mm" : "auto");
        }

        .header {
            text-align: center;
            border-bottom: 1px dashed #000;
            padding-bottom: 6px;
            margin-bottom: 6px;
        }

        .company-name {
            font-size: @(isThermal ? "16px" : "20px");
            font-weight: bold;
            text-transform: uppercase;
        }

        .small {
            font-size: @(isThermal ? "10px" : "11px");
        }

        .invoice-meta {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            border-bottom: 1px dashed #000;
            padding-bottom: 6px;
            font-size: @(isThermal ? "11px" : "13px");
        }

        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 6px;
        }

            table.items th {
                text-align: left;
                padding: 2px 0;
                border-bottom: 1px solid #000;
                font-size: @(isThermal ? "11px" : "12px");
                text-transform: uppercase;
            }

            table.items td {
                padding: 3px 0;
                border-bottom: 1px dotted #ccc;
                vertical-align: top;
                font-size: @(isThermal ? "11px" : "13px");
            }

        .num {
            text-align: right;
        }

        .totals-box {
            width: 100%;
            border-top: 1px dashed #000;
            padding-top: 4px;
            margin-bottom: 8px;
        }

        .totals-row {
            display: flex;
            justify-content: space-between;
            padding: 1px 0;
            font-size: @(isThermal ? "11px" : "13px");
        }

            .totals-row.net {
                font-weight: bold;
                font-size: @(isThermal ? "14px" : "16px");
                border-top: 1px solid #000;
                border-bottom: 1px solid #000;
                padding: 4px 0;
                margin-top: 2px;
            }

        .qr-container {
            text-align: center;
            margin: 8px 0;
        }

            .qr-container img {
                width: @(isThermal ? "80px" : "110px");
                height: @(isThermal ? "80px" : "110px");
            }

        .footer-note {
            text-align: center;
            font-size: @(isThermal ? "9px" : "11px");
            border-top: 1px dashed #000;
            padding-top: 4px;
            margin-top: 4px;
        }
    </style>
</head>
<body onload="window.print(); setTimeout(()=>window.close(), 500);">

    <div class="header">
        <div class="company-name">Organisation Name</div>
        <div class="small">@Model.Header.Location</div>
        <div class="small">User: @Model.Header.UserName</div>
    </div>

    <div class="invoice-meta">
        <div>
            <div><strong>Inv:</strong> @Model.Header.Code</div>
            <div class="small">Cust: @Model.Header.Customer</div>
        </div>
        <div style="text-align: right;">
            <div><strong>Date:</strong></div>
            <div class="small">@Model.Header.TransactionDate?.ToString("yy-MM-dd HH:mm")</div>
        </div>
    </div>

    <table class="items">
        <thead>
            <tr>
                <th>Item</th>
                <th class="num">Qty</th>
                @if (!isThermal)
                {
                    <th class="num">Price</th>
                }
                <th class="num">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>
                        @l.Description
                        @if (!string.IsNullOrEmpty(l.Attribute))
                        {
                            <div class="small">[@l.Attribute]</div>
                        }
                    </td>
                    <td class="num">@l.Quantity.ToString("0.##")</td>
                    @if (!isThermal)
                    {
                        <td class="num">@l.UnitSalePrice.ToString("0.00")</td>
                    }
                    <td class="num">@l.ChargedAmount.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="totals-box">
        <div class="totals-row">
            <span>Gross Amount</span>
            <span>@Model.Header.DocGrossAmount.ToString("0.00")</span>
        </div>
        @if (Model.Header.DocDiscountAmount > 0)
        {
            <div class="totals-row">
                <span>Discount</span>
                <span>-@Model.Header.DocDiscountAmount.ToString("0.00")</span>
            </div>
        }
        @if (Model.Header.DocTaxableAmount > 0)
        {
            <div class="totals-row">
                <span>Taxable Amount</span>
                <span>@Model.Header.DocTaxableAmount.ToString("0.00")</span>
            </div>
        }
        @if (Model.Header.DocSaleTaxAmount > 0)
        {
            <div class="totals-row">
                <span>Sales Tax</span>
                <span>@Model.Header.DocSaleTaxAmount.ToString("0.00")</span>
            </div>
        }
        @if (Model.Header.DocAdditionalTaxAmount > 0)
        {
            <div class="totals-row">
                <span>Additional Tax</span>
                <span>@Model.Header.DocAdditionalTaxAmount.ToString("0.00")</span>
            </div>
        }
        <div class="totals-row net">
            <span>NET AMOUNT</span>
            <span>@Model.Header.DocNetAmount.ToString("0.00")</span>
        </div>
        <div class="totals-row" style="margin-top: 4px;">
            <span>Due Amount</span>
            <span>@Model.Header.DueAmount.ToString("0.00")</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Header.FBRStamp))
    {
        <div class="small" style="text-align: center; margin-bottom: 4px;"><strong>FBR:</strong> @Model.Header.FBRStamp</div>
    }

    <div class="qr-container">
        <img src="@qrCodeUrl" alt="QR Code" />
        <div class="small">@Model.Header.Code</div>
    </div>

    <div class="footer-note">
        Thank You! Computer Generated Invoice
    </div>
</body>
</html>