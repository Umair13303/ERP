@using SharedUI.Models.Enums
@{
    Layout = "LayoutOne";
}

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 pb-3">
        <div>
            <h4 class="fw-bold mb-0">@ViewBag.DisplayName</h4>
            <p class="text-muted small mb-0">Fill in the details to create a new system record.</p>
        </div>
        <div>
            @if (ViewBag.OperationType == nameof(OperationType.INSERT_DATA_INTO_DB))
            {
                <button type="button" id="ButtonSaveData" class="btn btn-primary btn-sm px-4 shadow-sm">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save
                </button>
            }
            else
            {
                <button type="button" id="ButtonUpdateData" class="btn btn-success px-4 shadow-sm">
                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Update
                </button>
            }
        </div>
    </div>


    <form id="AFPaymentReceipt">
        @Html.Hidden("OperationType", (string)ViewBag.OperationType)
        @Html.Hidden("GuID")
        @{
            if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
            {
                <div class="card">
                    <div class="card-header">
                        <div class="row mb-0">
                            <div class="col-sm-12 col-md-6">
                                <div class="form-group">
                                    @Html.Label("DropDownListDocument", "Document (Payment)", new { @class = "col-form-label" })
                                    @Html.DropDownList("DocumentGuID", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", @id = "DropDownListDocument" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 bg-light">
                <span class="fw-semibold small text-secondary">
                    <i class="fa-solid fa-building me-1 text-primary"></i> PAYMENT DETAILS
                </span>
            </div>
            <div class="card-body py-3">
                <div class="row g-3 mb-2">
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            @Html.Label("TextBoxTransactionDate", "Transaction Date", new { @class = "col-form-label col-form-label-sm" })
                            @Html.TextBox("TransactionDate", null, new { @class = "form-control form-control-sm",required = "required",placeholder = "YYYY-MM-DD",@id = "TextBoxTransactionDate",@type = "date"   })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            @Html.Label("DropDownListLocation", "Location", new { @class = "col-form-label col-form-label-sm" })
                            @Html.DropDownList("LocationId", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", @id = "DropDownListLocation", required = "required" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            @Html.Label("DropDownListCustomer", "Customer", new { @class = "col-form-label col-form-label-sm" })
                            @Html.DropDownList("CustomerId", Enumerable.Empty<SelectListItem>(), "All Customers", new { @class = "form-select form-select-sm select2", @id = "DropDownListCustomer" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            <label class="col-form-label col-form-label-sm" for="DropDownListPaymentMode">Payment Mode <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm select2" id="DropDownListPaymentMode" name="PaymentMode" required>
                                <option value="">Select an option</option>
                                <option value="CASH">Cash</option>
                                <option value="BANK">Bank Transfer</option>
                                <option value="CHEQUE">Cheque</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                            <label class="col-form-label col-form-label-sm" for="TextBoxReferenceNo">Reference / Cheque No.</label>
                            <input type="text" class="form-control form-control-sm" id="TextBoxReferenceNo" name="ReferenceNo" placeholder="e.g. CHQ-00123" />
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-8">
                        <div class="form-group">
                            <label class="col-form-label col-form-label-sm" for="TextBoxRemarks">Remarks</label>
                            <input type="text" class="form-control form-control-sm" id="TextBoxRemarks" name="Remarks" placeholder="Optional note..." />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 bg-light d-flex align-items-center justify-content-between">
                <span class="fw-semibold small text-secondary">
                    <i class="fa-solid fa-list-check me-1 text-primary"></i> PENDING INVOICE LIST
                </span>
                <span class="badge bg-primary rounded-pill" id="BadgeInvoiceCount">0</span>
            </div>
            <div class="card-body py-3">

                <div class="row g-2 mb-3">
                    <div class="col-sm-12 col-md-5">
                        <input type="text" class="form-control form-control-sm" id="TextBoxSearchInvoice"
                               placeholder="Search by customer or invoice no..." />
                    </div>
                    <div class="col-sm-12 col-md-2">
                        <select class="form-select form-select-sm" id="DropDownListStatusFilter">
                            <option value="">All Statuses</option>
                            <option value="Pending">Pending</option>
                            <option value="Partial">Partial</option>
                        </select>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered table-hover align-middle" id="TablePendingInvoices" style="width:100%">
                        <thead class="table-light">
                            <tr>
                                <th style="width:3%;text-align:center">#</th>
                                <th style="width:18%">Invoice No.</th>
                                <th style="width:10%">Date</th>
                                <th style="width:9%;text-align:right">Total</th>
                                <th style="width:8%;text-align:right">Sale Tax</th>
                                <th style="width:8%;text-align:right">Addl. Tax</th>
                                <th style="width:9%;text-align:right">Gross</th>
                                <th style="width:8%;text-align:right">Discount</th>
                                <th style="width:9%;text-align:right">Net Amount</th>
                                <th style="width:8%;text-align:right">Paid</th>
                                <th style="width:8%;text-align:right">Balance</th>
                                <th style="width:8%;text-align:center">Status</th>
                            </tr>
                        </thead>
                        <tbody id="TBodyPendingInvoices">
                        </tbody>
                    </table>
                </div>
                <div class="text-muted small mt-1" id="LabelDataTableInfo"></div>

                <div class="row g-2 mt-3">
                    <div class="col-6 col-md-3">
                        <div class="bg-light rounded-2 p-3 text-center">
                            <div class="text-muted small mb-1">Total Invoices</div>
                            <div class="fw-bold fs-5" id="SumTotalInvoices">0</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light rounded-2 p-3 text-center">
                            <div class="text-muted small mb-1">Gross Amount</div>
                            <div class="fw-bold fs-5" id="SumGrossAmount">Rs. 0</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light rounded-2 p-3 text-center">
                            <div class="text-muted small mb-1">Total Paid</div>
                            <div class="fw-bold fs-5 text-success" id="SumTotalPaid">Rs. 0</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bg-light border border-primary rounded-2 p-3 text-center">
                            <div class="text-muted small mb-1">Total Balance</div>
                            <div class="fw-bold fs-5 text-primary" id="SumTotalBalance">Rs. 0</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </form>
</div>

<script src="~/js/accountnfinance/createupdate_afobinvoice_uiscript.js"></script>