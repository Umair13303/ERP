@using SharedUI.Models.Enums
@{
    Layout = "LayoutOne";
}

<div class="container-fluid py-2">

    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 pb-3">
        <div>
            <h5 class="fw-bold mb-0">@ViewBag.DisplayName</h5>
            @{
                string message = "Fill in the details to create a new stock adjustment record.";
                <p class="text-muted small mb-0">@message</p>
            }
        </div>
    </div>

    <form id="IInventoryAdjustmentForm">
        @Html.Hidden("OperationType", (string)ViewBag.OperationType)
        @Html.Hidden("GuID")

        @{
            if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <div class="row mb-0">
                            <div class="col-sm-12 col-md-6">
                                <div class="form-group">
                                    @Html.Label("DropDownListDocument", "Document (Inventory Adjustment)", new { @class = "col-form-label" })
                                    @Html.DropDownList("DocumentGuID", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", @id = "DropDownListDocument" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        <!-- HEADER INFORMATION -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="col-12 mt-2">
                    <div class="bg-light rounded-2 border-start border-primary border-4 p-2">
                        <span class="fw-bold text-primary small"><i class="fa-solid fa-file-lines me-2"></i> ADJUSTMENT INFORMATION</span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-6 border-end">
                        <div class="row g-1">
                            <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("DropDownListLocation", "Location", new { @class = "col-form-label" })
                            @Html.DropDownList("LocationId", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", required = "required", @id = "DropDownListLocation" })
                        </div>
                    </div>
                            <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("TextBoxTransactionDate", "Transaction Date", new { @class = "col-form-label" })
                            @Html.TextBox("TransactionDate", null, new { @class = "form-control form-control-sm simpleDate", type = "date", required = "required", @id = "TextBoxTransactionDate" })
                        </div>
                    </div>
                            <div class="col-sm-12 col-md-12">
                        <div class="form-group">
                            @Html.Label("TextBoxDescription", "Description", new { @class = "col-form-label" })
                            @Html.TextBox("Description", null, new { @class = "form-control form-control-sm", placeholder = "Provide Description!", required = "required", @id = "TextBoxDescription" })
                        </div>
                    </div>
                        </div>
                        <div class="row g-1">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("DropDownListProduct", "Product", new { @class = "col-form-label" })
                            @Html.DropDownList("ProductId", Enumerable.Empty<SelectListItem>(), "Search & select product...", new { @class = "form-select form-select-sm select2", @id = "DropDownListProduct" })
                        </div>
                    </div>

                    <div class="col-12 mt-2">
                        <div class="bg-light rounded-2 border-start border-warning border-1 p-2" id="DivVariantInformation" style="display:none">
                            <span class="fw-bold text-warning small"><i class="fa-solid fa-file-lines me-2"></i> VARIANT INFORMATION</span>
                            <div class="row mb-0 mt-0 fw-bold text-danger small" id="ContainerStockAttribute">
                            </div>
                        </div>
                    </div>
                    
                </div>
                        <div class="row g-1">
                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                                    @Html.Label("DropDownListInventoryAdjustmentType", "Adjustment Type", new { @class = "col-form-label" })
                                    @Html.DropDownList("InventoryAdjustmentTypeId", Enumerable.Empty<SelectListItem>(), "Select an option", new { @class = "form-select form-select-sm select2", required = "required", @id = "DropDownListInventoryAdjustmentType" })
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                            @Html.Label("TextBoxUnitPurchasePrice", "Purchase Price", new { @class = "col-form-label" })
                            @Html.TextBox("UnitPurchasePrice", 0.00, new { @class = "form-control form-control-sm", placeholder = "Provide Purchase Price/e!", required = "required", @id = "TextBoxUnitPurchasePrice", type = "number", min = "0" })
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                            @Html.Label("TextBoxUnitSalePrice", "Sale Price", new { @class = "col-form-label" })
                            @Html.TextBox("UnitSalePrice", 0.00, new { @class = "form-control form-control-sm", placeholder = "Provide Sale Price/e!", required = "required", @id = "TextBoxUnitSalePrice" ,type = "number", min = "0.00" })
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                            @Html.Label("TextBoxQuantityIn", "Quantity In", new { @class = "col-form-label" })
                            @Html.TextBox("QuantityIn", 0.00, new { @class = "form-control form-control-sm", placeholder = "Quantity Inward!", @id = "TextBoxQuantityIn" ,type = "number", min = "0" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-4">
                        <div class="form-group">
                            @Html.Label("TextBoxQuantityOut", "Quantity Out", new { @class = "col-form-label" })
                            @Html.TextBox("QuantityOut", 0.00, new { @class = "form-control form-control-sm", placeholder = "Quantity Outward!", @id = "TextBoxQuantityOut" ,type = "number", min = "0" })
                        </div>
                    </div>

                            @if (ViewBag.OperationType == nameof(OperationType.INSERT_DATA_INTO_DB))
                            {
                                <button type="button" id="ButtonSaveData" class="btn btn-primary btn-sm px-4 shadow-sm">
                                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save
                                </button>
                            }
                            else if (ViewBag.OperationType == nameof(OperationType.UPDATE_DATA_INTO_DB))
                            {
                                <button type="button" id="ButtonUpdateData" class="btn btn-success btn-sm px-4 shadow-sm">
                                    <i class="fa-solid fa-cloud-arrow-up me-1"></i> Update
                                </button>
                            }



                        </div> 
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    var LocationId = @ViewBag.LocationId;
    var SelectedAdjustmentTypeId = '@ViewBag.AdjustmentTypeId' || null;
</script>
<script src="~/js/inventory/createupdate_iadjustment_uiscript.js"></script>
