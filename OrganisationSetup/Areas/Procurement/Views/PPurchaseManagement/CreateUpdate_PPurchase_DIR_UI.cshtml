@using SharedUI.Models.Enums
@{
    Layout = "LayoutOne";
}

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between align-items-center border-bottom mb-4 pb-3">
        <div>
            <h5 class="fw-bold mb-0">@ViewBag.DisplayName</h5>
            <p class="text-muted small mb-0">Record direct purchases with immediate GL impact</p>
        </div>
    </div>

    <form id="DirectPurchaseForm">
        @Html.Hidden("OperationType", (string)ViewBag.OperationType)
        @Html.Hidden("GuID")

        <div class="card mb-3">
            <div class="card-body">
                <div class="col-12 mt-2">
                    <div class="bg-light rounded-2 border-start border-primary border-4 p-2">
                        <span class="fw-bold text-primary small"><i class="fa-solid fa-file-lines me-2"></i> PURCHASE INFORMATION</span>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("DropDownListLocation", "Location", new { @class = "col-form-label" })
                            @Html.DropDownList("LocationId", Enumerable.Empty<SelectListItem>(), "Select Location", new { @class = "form-select form-select-sm select2", required = "required", @id = "DropDownListLocation" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("TextBoxTransactionDate", "Purchase Date", new { @class = "col-form-label" })
                            @Html.TextBox("TransactionDate", DateTime.Now.ToString("yyyy-MM-dd"), new { @class = "form-control form-control-sm", type = "date", required = "required", @id = "TextBoxTransactionDate" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("DropDownListSupplier", "Supplier", new { @class = "col-form-label" })
                            @Html.DropDownList("SupplierId", Enumerable.Empty<SelectListItem>(), "Select Supplier", new { @class = "form-select form-select-sm select2", required = "required", @id = "DropDownListSupplier" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("TextBoxInvoiceNo", "Invoice/Bill No", new { @class = "col-form-label" })
                            @Html.TextBox("InvoiceNo", null, new { @class = "form-control form-control-sm", required = "required", placeholder = "Supplier invoice number", @id = "TextBoxInvoiceNo" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-12 col-md-12">
                        <div class="form-group">
                            @Html.Label("TextBoxDescription", "Purchase Description", new { @class = "col-form-label" })
                            @Html.TextArea("Description", null, new { @class = "form-control form-control-sm", rows = "2", placeholder = "Purchase details", @id = "TextBoxDescription" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <span class="fw-bold text-primary"><i class="fa-solid fa-list me-2"></i> PURCHASE LINE ITEMS</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="TableDirectPurchaseItems" class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th width="5%">#</th>
                                <th width="25%">Product</th>
                                <th width="10%">Quantity</th>
                                <th width="12%">Unit Price</th>
                                <th width="12%">Amount</th>
                                <th width="15%">GL Account</th>
                                <th width="10%">Action</th>
                            </tr>
                        </thead>
                        <tbody id="TablePurchaseItemsBody">
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="4" class="text-end fw-bold">TOTAL:</td>
                                <td class="fw-bold" id="TotalAmount">0.00</td>
                                <td></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            @Html.Label("DropDownListProduct", "Add Product", new { @class = "col-form-label" })
                            @Html.DropDownList("ProductId", Enumerable.Empty<SelectListItem>(), "Select Product", new { @class = "form-select form-select-sm select2", @id = "DropDownListProduct" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-2">
                        <div class="form-group">
                            @Html.Label("TextBoxLineQuantity", "Qty", new { @class = "col-form-label" })
                            @Html.TextBox("LineQuantity", "", new { @class = "form-control form-control-sm", type = "number", step = "0.01", @id = "TextBoxLineQuantity" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-2">
                        <div class="form-group">
                            @Html.Label("TextBoxLinePrice", "Price", new { @class = "col-form-label" })
                            @Html.TextBox("LinePrice", "", new { @class = "form-control form-control-sm", type = "number", step = "0.01", @id = "TextBoxLinePrice" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="form-group">
                            @Html.Label("DropDownListGLAccount", "GL Account", new { @class = "col-form-label" })
                            @Html.DropDownList("GLAccountId", Enumerable.Empty<SelectListItem>(), "Select Account", new { @class = "form-select form-select-sm select2", @id = "DropDownListGLAccount" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-2 d-flex align-items-end">
                        <button type="button" id="ButtonAddLineItem" class="btn btn-sm btn-info w-100">
                            <i class="fa-solid fa-plus me-1"></i> Add
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("TextBoxTaxAmount", "Tax Amount", new { @class = "col-form-label" })
                            @Html.TextBox("TaxAmount", "0.00", new { @class = "form-control form-control-sm", type = "number", step = "0.01", @id = "TextBoxTaxAmount" })
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            @Html.Label("TextBoxDiscount", "Discount", new { @class = "col-form-label" })
                            @Html.TextBox("Discount", "0.00", new { @class = "form-control form-control-sm", type = "number", step = "0.01", @id = "TextBoxDiscount" })
                        </div>
                    </div>
                </div>

                <div class="row mt-3 p-3 bg-light rounded">
                    <div class="col-sm-12 col-md-4 text-end fw-bold">
                        Subtotal: <span id="SubtotalDisplay">0.00</span>
                    </div>
                    <div class="col-sm-12 col-md-4 text-end fw-bold">
                        Tax: <span id="TaxDisplay">0.00</span>
                    </div>
                    <div class="col-sm-12 col-md-4 text-end fw-bold text-primary" style="font-size: 16px;">
                        Total: <span id="GrandTotalDisplay">0.00</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-end">
            <button type="button" id="ButtonSaveData" class="btn btn-primary btn-sm px-4">
                <i class="fa-solid fa-cloud-arrow-up me-1"></i> Save Purchase
            </button>
        </div>
    </form>
</div>

<script src="~/js/inventory/DirectPurchase_UIScript.js"></script>